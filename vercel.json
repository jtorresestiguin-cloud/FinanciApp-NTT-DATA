{
  "version": 2,
  "functions": {
    "api/eu-grants.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 30,
      "memory": 256
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Cache-Control",                "value": "s-maxage=3600, stale-while-revalidate=600" }
      ]
    }
  ]
}
